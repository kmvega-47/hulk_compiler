type Shape
{
    area() => 0;
}

type Circle(radius) inherits Shape
{
    radius = radius;
    area() => PI * self.radius ^ 2;
}

type Square(side) inherits Shape
{
    side = side;
    area() => self.side ^ 2;
}

function print_area(s)
{
    print(s.area());
}

{
    print_area(new Circle(5));
    print_area(new Square(4));
}
