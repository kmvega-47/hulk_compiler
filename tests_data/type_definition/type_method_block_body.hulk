type Logger
{
    messages = "";

    log(msg: String)
    {
        self.messages := self.messages @ msg @ "\n";
    }

    print_all()
    {
        print(self.messages);
    }
}

let logger = new Logger() in
{
    logger.log("First message");
    logger.log("Second message");
    logger.print_all();
}
