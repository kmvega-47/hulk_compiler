{
    // aritmetica: suma, resta, mult, div, mod, pow
    print(2 + 3 * 4 - 1);
    print(10 / 3);
    print(10 % 3);
    print(2 ^ 10);

    // concatenacion: string con string
    print("Hola " @ "Mundo");

    // concatenacion: string con number
    print("El numero es " @ 42);

    // concatenacion con espacio
    print("Hola" @@ "Mundo");

    // logica: and, or
    print(true & false);
    print(true | false);

    // comparacion: ==, !=, <, >, <=, >=
    print(5 == 5);
    print(5 != 3);
    print(3 < 5);
    print(5 > 3);
    print(3 <= 3);
    print(5 >= 4);

    // aritmetica nested
    print((2 + 3) * (4 - 1) ^ 2);
}