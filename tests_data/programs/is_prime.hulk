function is_prime(n) =>
    if (n < 2)
        false
    else
    {
        let i = 2 in
        while (i * i <= n)
        {
            if (n % i == 0)
                i := n + 1
            else
                i := i + 1;
        }
    };

{
    print(is_prime(7));
    print(is_prime(10));
    print(is_prime(9973));
}
