type Point(x : Number, y : Number) {
    x = x;
    y = y;

    getX() => self.x;
    getY() => self.y;
    setX(v) => self.x := v;
    setY(v) => self.y := v;
    sum() => self.x + self.y;
}

type Point3D(z) inherits Point(z * 2, z + 1) {
    z = z;

    getZ() => self.z;
    setZ(v) => self.z := v;
    sumAll() => self.getX() + self.getY() + self.z;
}

{
    let p = new Point(3, 4) in {
        p.setX(10);
        p.setY(20);
        print(p.getX());
        print(p.getY());
        print(p.sum());
    };

    let p3 = new Point3D(5) in {
        p3.setZ(3);
        print(p3.getZ());
        print(p3.sumAll());
    };
    0;
}