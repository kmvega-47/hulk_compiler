type A {
    value = 0;
    getValue() => self.value;
}

type B inherits A {
    increment() => self.value := self.value + 1;
}

type C inherits A {
    decrement() => self.value := self.value - 1;
}

let x : A = if (rand() < 0.5) new B() else new C() in
if (x is B)
    let y : B = x as B in {
        y.increment();
        print("B: " @ y.getValue());
    }
else {
    print("Not B");
};