function test_reassign(p: Number) {
        print(p);
        p := 100;
        print(p);
    }
    
{
    // reassign_variable
    let x = 10 in {
        print(x);
        x := 20;
        print(x);
    };

    // reassign_multiple
    let a = 1, b = 2 in {
        print(a);
        print(b);
        a := 10;
        b := 20;
        print(a);
        print(b);
    };

    // reassign_shadowing
    let x = 1 in {
        print(x);
        let x = 2 in {
            print(x);
            x := 5;
            print(x);
        };
        print(x);
    };

    // reassign_function_parameter
    test_reassign(50);

    // reassign_as_subexpression
    let x = 0 in {
        print(1 + (x := 5));
        print(x);
    };

    // reassign_encadenado
    let a = 1, b = 2 in 
    {
        a := b := 10;
        print(a);
        print(b);
    };
}

