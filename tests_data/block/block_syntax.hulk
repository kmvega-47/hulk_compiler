{
    // Bloque vacío
    {};

    // Una expresión sin ;
    {
        42
    };

    // Una expresión con ;
    {
        42;
    };

    // Múltiples expresiones sin ; final
    {
        1;
        2;
        3
    };

    // Múltiples expresiones con ; final
    {
        "hello";
        true;
        3.14;
    };

    // Bloques anidados con diferentes combinaciones
    {
        {
            1
        };
        {
            2;
        };
        {
            3;
            4
        };
        5
    };

    // Bloque como cuerpo de let
    let x = {
        10;
        20
    } in print(x);

    // Bloque en condicional
    if (true) {
        print("yes");
        print("no")
    }
}