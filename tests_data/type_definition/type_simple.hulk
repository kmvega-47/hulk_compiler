type Point(x, y)
{
    x = x;
    y = y;

    getX() => self.x;
    getY() => self.y;

    setX(x) => self.x := x;
    setY(y) => self.y := y;

    distance_to_origin() => sqrt(self.x ^ 2 + self.y ^ 2);
}

let pt = new Point(3, 4) in
{
    print(pt.getX());
    print(pt.getY());
    print(pt.distance_to_origin());
}
