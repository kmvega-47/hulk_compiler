// Definiciones de tipos
type Point(x, y) {
    x = x;
    y = y;
    getX() => self.x;
    getY() => self.y;
    dist() => sqrt(self.x ^ 2 + self.y ^ 2);
}

type Point3D(x, y, z) inherits Point(x, y) {
    z = z;
    getZ() => self.z;
    dist() => sqrt(self.getX() ^ 2 + self.getY() ^ 2 + self.z ^ 2);
}

type PolarPoint(phi, rho) inherits Point(rho * sin(phi), rho * cos(phi)) {
    rho() => sqrt(self.getX() ^ 2 + self.getY() ^ 2);
    phi() => self.getY() / self.getX();
}

// Definiciones de funciones (inline, recursivas, full‑form)
function tan(x) => sin(x) / cos(x);
function cot(x) => 1 / tan(x);

function factorial(n) =>
    if (n == 0) 1
    else n * factorial(n - 1);

function operate(x, y) {
    print("" @ (x + y));
    print("" @ (x - y));
    print("" @ (x * y));
    print("" @ (x / y));
}

// Expresión global final
{
    print("" @ tan(PI / 4));
    print("" @ factorial(5));

    let pt = new Point(3, 4) in {
        print("" @ pt.getX());
        print("" @ pt.getY());
        print("" @ pt.dist());
    };

    let pt3 = new Point3D(3, 4, 5) in {
        print("" @ pt3.getX());
        print("" @ pt3.getY());
        print("" @ pt3.getZ());
        print("" @ pt3.dist());
    };

    let pp = new PolarPoint(1, 2) in {
        print("" @ pp.rho());
        print("" @ pp.phi());
    };

    operate(10, 2);
}