{
    // single_error_at_binding: error en inicializador
    let x = 5 + "a" in print(x);

    // multiple_errors_at_binding: errores en varios bindings
    let a = true + 1, b = "x" - 2 in print(a);

    // error_at_body: error en el cuerpo
    let x = 5 in print(x + "texto");

    // mixed_errors: error en binding y en body
    let y = !3 in print(y + false);

    // type_mismatch: tipo anotado no coincide con inicializador
    let a: Number = "hola" in print(a);
}