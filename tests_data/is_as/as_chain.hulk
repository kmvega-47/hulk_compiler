type Animal { kind() => "animal"; }
type Mammal inherits Animal { kind() => "mammal"; }
type Dog inherits Mammal { kind() => "dog"; }

let a: Animal = new Dog() in
{
    if (a is Mammal)
        let m: Mammal = a as Mammal in
            print(m.kind());
    if (a is Dog)
        let d: Dog = a as Dog in
            print(d.kind());
}
