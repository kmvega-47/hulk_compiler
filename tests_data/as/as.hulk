type A {
    value() => 10;
}
type B inherits A {
    value() => 20;
}

{
    // as sobre variable Object hacia tipo concreto
    let x: Object = new B() in {
        let y = x as B in print(y.value());
    };

    // as sobre variable concreta hacia ancestro
    let b = new B() in {
        let a = b as A in print(a.value());
    }
}
