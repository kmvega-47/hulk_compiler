// Definiciones de tipos
type Simple {
    x = 0;
    getX() => self.x;
}

type Point(x, y) {
    x = x;
    y = y;
    getX() => self.x;
    getY() => self.y;
    setX(newX) => self.x := newX;
    setY(newY) => self.y := newY;
    dist() => sqrt(self.x ^ 2 + self.y ^ 2);
}

type Point3D(x, y, z) inherits Point(x, y) {
    z = z;
    getZ() => self.z;
    dist() => sqrt(self.x ^ 2 + self.y ^ 2 + self.z ^ 2);
}

type PolarPoint(phi, rho) inherits Point(rho * sin(phi), rho * cos(phi)) {
    rho() => sqrt(self.x ^ 2 + self.y ^ 2);
    phi() => atan2(self.y, self.x);
}

// Expresión global que utiliza los tipos para que el programa sea válido
{
    let pt = new Point(3, 4) in {
        print(pt.getX());
        print(pt.getY());
        print(pt.dist());
    };
    let pt3 = new Point3D(3, 4, 5) in {
        print(pt3.getX());
        print(pt3.getY());
        print(pt3.getZ());
        print(pt3.dist());
    };
    let pp = new PolarPoint(1, 2) in {
        print(pp.rho());
        print(pp.phi());
    };
    let s = new Simple() in print(s.getX());
}