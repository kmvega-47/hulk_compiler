{
    // single_error: una expresion con error semantico
    {
    print(!"hola");
    };

    // multiple_errors: varias expresiones con errores
    {
        print(5 + "texto");
        print(true / 3);
        print("a" < 4);
    };

    // last_expression_error: error en la ultima expresion
    print(1 - false);
}