type Vector2D(x, y)
{
    x = x;
    y = y;

    get_x() => self.x;
    get_y() => self.y;

    add(other: Vector2D): Vector2D =>
        new Vector2D(self.x + other.get_x(), self.y + other.get_y());

    dot(other: Vector2D): Number => self.x * other.get_x() + self.y * other.get_y();

    length() => sqrt(self.dot(self));

    normalize(): Vector2D =>
    {
        let len = self.length() in
        new Vector2D(self.x / len, self.y / len);
    };

    to_string() =>
        "(" @ self.x @ ", " @ self.y @ ")";
}

{
    let v1 = new Vector2D(3, 4) in
    let v2 = new Vector2D(1, 2) in
    {
        print(v1.length());
        print(v1.dot(v2));
        print(v1.add(v2).to_string());
    }
}
