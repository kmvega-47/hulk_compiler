{
    // single_variable
    let x = 10 in print(x);

    // multiple_variables
    let a = 1, b = 2, c = 3 in {
        print(a);
        print(b);
        print(c);
    };

    // multiple_variables_without_annotation
    let p = 3.14, q = "hola", r = true in {
        print(p);
        print(q);
        print(r);
    };

    // variable_dependency: b depende de a
    let a = 3, b = a + 1 in print(b);

    // same_variable: shadowing en el mismo let
    let a = 3, a = 4 in print(a);

    // nested: lets anidados
    let x = 1 in {
        print(x);
        let x = 2 in {
            print(x);
            let y = 3 in print(x + y);
        };
        print(x);
    };

    // constant_shadowing: sombrear PI
    let PI = 10 in print(PI);
}