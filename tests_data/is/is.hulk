type A {}
type B inherits A {}

{
    let x: Object = new B() in {
        // is sobre variable Object (runtime)
        print(x is B);
        print(x is A);
        print(x is Object);
    };

    // is sobre variable de tipo concreto (compilacion)
    let y = new A() in {
        print(y is A);
        print(y is B);
    };

    let y = new B() in print(y is A);  // B is A, debería ser true
}
