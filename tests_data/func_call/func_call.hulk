function double(x: Number): Number => x * 2;
function add(x: Number, y: Number): Number => x + y;

{
    // call_builtin
    print(sqrt(16));

    // call_userdefined
    print(double(5));
    print(add(3, 7));

    // nested_calls
    print(double(add(2, 3)));
    print(add(double(4), sqrt(25)));
}