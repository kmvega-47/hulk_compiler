{
    print(1 + 2);
    print(10 - 4);
    print(6 * 7);
    print(8 / 2);
    print(10 % 3);
    print(2 ^ 3);
    print(true & false);
    print(true | false);
    print(1 == 2);
    print(1 != 2);
    print(1 < 2);
    print(1 > 2);
    print(1 <= 2);
    print(1 >= 2);
    print("Hello" @ " " @ "World");
    print("Hello" @@ "World");
    print((1 + 2) * (3 + 4));
}