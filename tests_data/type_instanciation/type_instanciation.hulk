// Definiciones auxiliares
type Point(x, y) {
    x = x;
    y = y;
    getX() => self.x;
    getY() => self.y;
}

type NamedPoint(name, x, y) {
    name = name;
    x = x;
    y = y;
    getName() => self.name;
}

// Expresión global con instanciaciones
{
    // Sin argumentos (atributos inicializados con valores por defecto)
    let p1 = new Point(0, 0) in {
        print(p1.getX());
        print(p1.getY());
    };

    // Con argumentos
    let p2 = new Point(3, 4) in {
        print(p2.getX());
        print(p2.getY());
    };

    // Instanciación con nombre y argumentos
    let np = new NamedPoint("P", 5, 6) in {
        print(np.getName());
        print(np.getX());
        print(np.getY());
    };

    // Instanciación como parte de una expresión más compleja
    let p3 = new Point(1, 2) in print(p3.getX() + p3.getY());
}