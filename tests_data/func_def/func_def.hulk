function sum(x: Number, y: Number): Number => x + y;
function mul(x, y) => x * y;
function greet(name: String) {
    print("Hola " @ name);
}
function add_one(x: Number): Number => x + 1;
function is_even(x: Number): Bool => if (x == 0) true else is_odd(x - 1);
function is_odd(x: Number): Bool => if (x == 0) false else is_even(x - 1);

{
    print(sum(3, 4));
    print(mul(5, 6));
    greet("Mundo");
    print(add_one(41));
    print(is_even(10));
    print(is_even(11));
    print(is_odd(10));
    print(is_odd(11));
}